---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { gcpInfraLessons } from '../../../lessons';

const baseUrl = import.meta.env.BASE_URL;

// Group by phase
const phases = gcpInfraLessons.reduce((acc, lesson) => {
  if (!acc[lesson.phase]) {
    acc[lesson.phase] = { phase: lesson.phase, title: lesson.phaseTitle, lessons: [] };
  }
  acc[lesson.phase].lessons.push(lesson);
  return acc;
}, {} as Record<number, { phase: number; title: string; lessons: typeof gcpInfraLessons }>);

const phaseList = Object.values(phases).sort((a, b) => a.phase - b.phase);
const publishedCount = gcpInfraLessons.filter(l => l.status === 'published').length;

const phaseColors: Record<number, { bg: string; text: string }> = {
  1: { bg: '#E6F1FB', text: '#185FA5' },
  2: { bg: '#E1F5EE', text: '#0F6E56' },
  3: { bg: '#FAEEDA', text: '#854F0B' },
  4: { bg: '#EEEDFE', text: '#3C3489' },
  5: { bg: '#FAECE7', text: '#993C1D' },
  6: { bg: '#FBEAF0', text: '#993556' },
};
---

<BaseLayout title="GCP general infrastructure curriculum" description="Architect-grade GCP infrastructure curriculum, 19 lessons covering the foundational layer of Google Cloud.">
  <div class="container">
    <header class="curriculum-hero">
      <span class="curriculum-tag">GCP · Curriculum</span>
      <h1>General infrastructure</h1>
      <p class="curriculum-tagline">From the resource hierarchy to Terraform pipelines. The foundational layer of Google Cloud, the way an architect actually thinks about it.</p>
      <div class="curriculum-stats">
        <span><strong>{publishedCount}</strong> of {gcpInfraLessons.length} lessons published</span>
        <span>·</span>
        <span>6 phases</span>
        <span>·</span>
        <span>~15 min per lesson</span>
      </div>
    </header>

    {phaseList.map(({ phase, title, lessons }) => (
      <section class="phase-section">
        <div class="phase-header">
          <span class="phase-badge" style={`background: ${phaseColors[phase].bg}; color: ${phaseColors[phase].text};`}>Phase {phase}</span>
          <h2>{title}</h2>
        </div>
        <ol class="lesson-list">
          {lessons.map((l) => (
            <li class={`lesson-item ${l.status}`}>
              {l.status === 'published' ? (
                <a href={`${baseUrl}/gcp/infra/${l.slug}/`} class="lesson-link">
                  <div class="lesson-row">
                    <div class="lesson-number">{l.lesson}</div>
                    <div class="lesson-text">
                      <div class="lesson-title">{l.title}</div>
                      <div class="lesson-desc">{l.description}</div>
                    </div>
                    <div class="lesson-status">→</div>
                  </div>
                </a>
              ) : (
                <div class="lesson-row planned">
                  <div class="lesson-number">{l.lesson}</div>
                  <div class="lesson-text">
                    <div class="lesson-title">{l.title}</div>
                    <div class="lesson-desc">{l.description}</div>
                  </div>
                  <div class="lesson-status planned-tag">Planned</div>
                </div>
              )}
            </li>
          ))}
        </ol>
      </section>
    ))}
  </div>

  <style>
    .curriculum-hero {
      text-align: center;
      padding: 1rem 0 3rem;
      border-bottom: 0.5px solid var(--color-border);
      margin-bottom: 2.5rem;
    }
    .curriculum-tag {
      display: inline-block;
      font-size: 12px;
      color: var(--color-text-tertiary);
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .curriculum-hero h1 {
      font-size: 36px;
      margin-bottom: 1rem;
    }
    .curriculum-tagline {
      font-size: 17px;
      color: var(--color-text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }
    .curriculum-stats {
      margin-top: 1.5rem;
      font-size: 13px;
      color: var(--color-text-tertiary);
      display: flex;
      gap: 8px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .curriculum-stats strong {
      color: var(--color-accent);
      font-weight: 500;
    }
    .phase-section {
      margin-bottom: 2.5rem;
    }
    .phase-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 1rem;
    }
    .phase-badge {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: var(--radius-sm);
    }
    .phase-header h2 {
      margin: 0;
      font-size: 20px;
    }
    .lesson-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .lesson-item {
      margin: 0;
    }
    .lesson-link {
      display: block;
      color: var(--color-text-primary);
      text-decoration: none;
    }
    .lesson-row {
      display: grid;
      grid-template-columns: 60px 1fr auto;
      align-items: center;
      gap: 16px;
      padding: 1rem 1.25rem;
      background: var(--color-bg-card);
      border: 0.5px solid var(--color-border);
      border-radius: var(--radius-md);
      margin: 6px 0;
      transition: border-color 0.15s;
    }
    .lesson-link:hover .lesson-row {
      border-color: var(--color-accent);
    }
    .lesson-row.planned {
      opacity: 0.55;
    }
    .lesson-number {
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--color-text-tertiary);
    }
    .lesson-title {
      font-weight: 500;
      font-size: 15px;
      margin-bottom: 2px;
    }
    .lesson-desc {
      font-size: 13px;
      color: var(--color-text-secondary);
      line-height: 1.5;
    }
    .lesson-status {
      color: var(--color-accent);
      font-size: 18px;
    }
    .planned-tag {
      font-size: 11px;
      color: var(--color-text-tertiary);
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }
  </style>
</BaseLayout>
