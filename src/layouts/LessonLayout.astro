---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  lesson: string;
  phase: number;
  description: string;
  analogy?: string;
  prevLesson?: { slug: string; title: string; lesson: string };
  nextLesson?: { slug: string; title: string; lesson: string };
  totalLessons: number;
  currentNumber: number;
}

const { title, lesson, phase, description, analogy, prevLesson, nextLesson, totalLessons, currentNumber } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const progressPct = Math.round((currentNumber / totalLessons) * 100);
---

<BaseLayout title={`Lesson ${lesson} — ${title}`} description={description}>
  <article class="container lesson-article">
    <div class="lesson-progress">
      <div class="progress-meta">
        <span>Phase {phase} · Lesson {lesson}</span>
        <span>{currentNumber} of {totalLessons}</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" style={`width: ${progressPct}%`}></div>
      </div>
    </div>

    <header class="lesson-header">
      <h1>{title}</h1>
      {analogy && <p class="lesson-analogy"><em>Analogy:</em> {analogy}</p>}
    </header>

    <div class="lesson-content">
      <slot />
    </div>

    <nav class="lesson-nav">
      {prevLesson ? (
        <a href={`${baseUrl}/gcp/infra/${prevLesson.slug}/`} class="lesson-nav-link prev">
          <span class="nav-direction">← Previous</span>
          <span class="nav-title">Lesson {prevLesson.lesson} · {prevLesson.title}</span>
        </a>
      ) : <div></div>}
      {nextLesson ? (
        <a href={`${baseUrl}/gcp/infra/${nextLesson.slug}/`} class="lesson-nav-link next">
          <span class="nav-direction">Next →</span>
          <span class="nav-title">Lesson {nextLesson.lesson} · {nextLesson.title}</span>
        </a>
      ) : <div></div>}
    </nav>

    <a href={`${baseUrl}/gcp/infra/`} class="back-to-toc">← Back to curriculum</a>
  </article>

  <style>
    .lesson-article {
      max-width: var(--content-width);
    }
    .lesson-progress {
      margin-bottom: 2rem;
    }
    .progress-meta {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: var(--color-text-tertiary);
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .progress-bar {
      height: 3px;
      background: var(--color-bg-secondary);
      border-radius: 2px;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: var(--color-accent);
      border-radius: 2px;
      transition: width 0.3s ease;
    }
    .lesson-header {
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 0.5px solid var(--color-border);
    }
    .lesson-analogy {
      color: var(--color-text-secondary);
      font-size: 15px;
      margin-top: 8px;
    }
    .lesson-content :global(h2) {
      margin-top: 2.5rem;
    }
    .lesson-content :global(p),
    .lesson-content :global(li) {
      font-size: 16px;
      line-height: 1.7;
    }
    .lesson-nav {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin: 3rem 0 1.5rem;
      padding-top: 2rem;
      border-top: 0.5px solid var(--color-border);
    }
    .lesson-nav-link {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 1rem 1.25rem;
      background: var(--color-bg-card);
      border: 0.5px solid var(--color-border);
      border-radius: var(--radius-lg);
      color: var(--color-text-primary);
      text-decoration: none;
      transition: border-color 0.15s, transform 0.15s;
    }
    .lesson-nav-link:hover {
      border-color: var(--color-accent);
      text-decoration: none;
    }
    .lesson-nav-link.next {
      text-align: right;
    }
    .nav-direction {
      font-size: 12px;
      color: var(--color-text-tertiary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .nav-title {
      font-size: 14px;
      font-weight: 500;
    }
    .back-to-toc {
      display: inline-block;
      margin-top: 1rem;
      font-size: 14px;
      color: var(--color-text-secondary);
    }
    @media (max-width: 600px) {
      .lesson-nav {
        grid-template-columns: 1fr;
      }
      .lesson-nav-link.next {
        text-align: left;
      }
    }
  </style>
</BaseLayout>
