---
// StickyNote — a slightly rotated handwritten-style aside.
// Usage: <StickyNote>watch out: AWS does this differently!</StickyNote>
---

<div class="sticky-note">
  <slot />
</div>

<style>
  .sticky-note {
    display: block;
    margin: 1.5rem auto;
    max-width: 380px;
    padding: 14px 18px 16px;
    background: linear-gradient(180deg, #fff8c4, #fff1a8);
    color: #3a2c10;
    font-family: 'Marker Felt', 'Bradley Hand', Chalkduster, cursive;
    font-size: 15px;
    line-height: 1.45;
    transform: rotate(-1.2deg);
    box-shadow: 2px 4px 10px rgba(0,0,0,0.18), 0 1px 0 rgba(0,0,0,0.05) inset;
    border-radius: 2px;
    position: relative;
  }
  .sticky-note::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 50%;
    width: 60px;
    height: 16px;
    background: rgba(255, 200, 80, 0.4);
    transform: translateX(-50%) rotate(-2deg);
    border-radius: 2px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  .sticky-note strong {
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 2px;
  }
  .sticky-note em {
    font-style: italic;
  }
</style>
